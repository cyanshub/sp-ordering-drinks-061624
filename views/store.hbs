<div class="row" style="max-width: 1080px; margin: 0 auto;">

  <div class="d-flex align-items-center">
    <div class="col col-lg-6">
      <img class="img-responsive center-block" src="{{store.cover}}"
        style="width:auto; max-width: 390px; margin-bottom: 1rem; transition: opacity 0.5s; opacity:0;"
        onload="this.style.opacity=1;">
      <br>
    </div>
    <div class="col-12 col-lg-6 ms-5">
      <h3 class="mb-2">
        <strong>{{store.name}}</strong>
      </h3>
      <ul class="list-unstyled">

        <li><strong>地址: </strong> {{store.address}}</li>
        <li><strong>電話: </strong>{{store.phone}}</li>
      </ul>

      <a class="btn btn-outline-primary mt-2 me-3" href="#drink-menu">菜單</a>
      <a class="btn btn-outline-secondary mt-2" href="/stores">返回</a>

    </div>
  </div>

  <hr style="border: none; border-top: 3px solid black;">

  
  {{!-- 將商品加入購物車 --}}
  {{>order-form storeId=store.id}}

</div>