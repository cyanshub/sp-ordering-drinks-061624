{{!-- 導入頁籤 --}}
{{>store-tabs route = 'store'}}

<div style="max-width: 1080px; margin-left: 0; margin-right: auto;">

  <div class="row d-flex align-items-center">
    <div class="col-lg-5 col-sm-12 ms-5">
      <img class="img-responsive center-block" src="{{store.cover}}"
        style="width:auto; max-width: 390px; margin-bottom: 1rem; transition: opacity 0.5s; opacity:0;"
        onload="this.style.opacity=1;">
      <br>
    </div>
    <div class="col-lg-5 col-sm-12 ms-5">
      <h3 class="my-2">
        <strong>{{store.name}}</strong>
      </h3>
      <ul class="list-unstyled">

        <li><strong>地址: </strong> {{store.address}}</li>
        <li><strong>電話: </strong>{{store.phone}}</li>
      </ul>

      <a class="btn btn-outline-secondary mt-2 me-3" href="/stores">返回</a>
      <a class="btn btn-outline-primary mt-2" href="#drink-menu">菜單</a>

    </div>
  </div>

  <hr style="border: none; border-top: 1px solid black;">

  
  {{!-- 將商品加入購物車 --}}
  <div class="ms-3">
    {{>order-form storeId=store.id}}
  </div>
  
</div>