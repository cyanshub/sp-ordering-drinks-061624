{{!-- 前台頁籤 --}}
{{> store-tabs route = 'orders'}}

{{#if orders}}

<div class="mt-2">
  {{!-- 列出訂單資訊 --}}
  <div id="table-orders">
    <table cellspacing="0">

      {{!-- 表頭 --}}
      <thead>
        <tr>
          <th style="min-width: 60px;">用戶</th>
          <th style="min-width: 60px;">店家</th>
          <th style="min-width: 60px;">數量</th>
          <th style="min-width: 100px;">商品</th>
          <th style="min-width: 130px;">規格</th>
          <th style="min-width: 60px;">金額</th>
          <th style="min-width: 110px;">時間</th>
          
        </tr>
      </thead>

      {{!-- 表格 --}}
      <tbody>
        {{#each orders}}
        <tr>
          <td>{{this.User.name}}</td>
          <td>{{this.Store.name}}</td>
          <td>{{this.amount}}杯</td>
          <td>{{this.Drink.name}}</td>
          <td>{{this.Size.level}}、{{this.Sugar.level}}、{{this.Ice.level}}</td>
          <td>{{multiply this.Drink.price this.amount}}元</td>
          <td>{{formatTime this.createdAt}}</td>
        </tr>
        {{/each}}
      </tbody>

    </table>
  </div>

  {{!-- 取得資料總數, 顯示全部資料的按鈕 --}}
  <p class="small btn-color">
    {{> pagination-toggle color = 'btn-color'}}
  </p>


  {{!-- 新增頁碼器 --}}
  <div class="mt-3 d-flex justify-content-center align-items-center table-width">
    {{> pagination}}
  </div>
</div>


{{else}}
<a href="/stores">
  <h5 class="mt-1" style="line-height: 1.5rem">尚無購買記錄...<br>來去逛逛吧!</h5>
</a>
{{/if}}

